	<include file="$(find imu_launch)/launch/imu_$(arg imu_package)_msg.launch"/>
	
	<include file="$(find lslidar_c16_decoder)/launch/lslidar_c16.launch"/>
	
	<include file="$(find greencar_can_test_3)/launch/greencar_control.launch"/>
	
	<include file="$(find hdl_localization)/launch/hdl_localization.launch"/>
	
	<include file="$(find movebase_test)/launch/movebase_local.launch"/>
	
</launch>
